{
  "name": "dorado-cli",
  "version": "0.10.1",
  "description": "CLI tool for enforcing dorado workflow",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "dorado": "dist/cli.js"
  },
  "scripts": {
    "start": "node dist/cli.js",
    "help": "node dist/cli.js --help",
    "version": "node dist/cli.js --version",
    "doctor": "node scripts/release-doctor.js",
    "index:rebuild": "node dist/tools/build-index.js",
    "release:smoke": "node scripts/release-smoke.js"
  },
  "keywords": [
    "dorado",
    "workflow",
    "cli",
    "automation"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "body-parser": "^2.2.2",
    "chalk": "^5.3.0",
    "commander": "^11.1.0",
    "cors": "^2.8.6",
    "express": "^4.22.1",
    "fs-extra": "^11.2.0",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.0",
    "open": "^9.1.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  }
}
